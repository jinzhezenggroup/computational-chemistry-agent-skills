---
import Base from "../layouts/Base.astro";
import skills from "../data/skills.json";

const base = Astro.base || "";
const href = (p: string) => `${base}${p}`;

const qRaw = Astro.url.searchParams.get("q") || "";
const q = qRaw.toLowerCase();
const cat = Astro.url.searchParams.get("cat") || "";

const categories = Array.from(
  new Set(skills.map((s) => s.category).filter(Boolean))
).sort();

let filtered = skills;
if (cat) filtered = filtered.filter((s) => s.category === cat);
if (q) {
  filtered = filtered.filter((s) =>
    (s.name || "").toLowerCase().includes(q) ||
    (s.description || "").toLowerCase().includes(q) ||
    (s.compatibility || "").toLowerCase().includes(q) ||
    (s.category || "").toLowerCase().includes(q)
  );
}

const countsByCat = Object.fromEntries(
  categories.map((c) => [c, skills.filter((s) => s.category === c).length])
);
---

<Base title="Skills Catalog">
  <section class="hero">
    <h1>Skills Catalog</h1>
    <p>
      A small, auto-generated catalog for
      <a href="https://github.com/jinzhezenggroup/computational-chemistry-agent-skills" target="_blank" rel="noreferrer">computational-chemistry-agent-skills</a>.
      Search, browse by category, and open a skill page to view the full <code>SKILL.md</code> content.
    </p>

    <div class="hero-row">
      <form class="search" method="get" action={href("/") }>
        <input name="q" value={qRaw} placeholder="Search skills (name / description / compatibility / category)…" />
        {cat ? <input type="hidden" name="cat" value={cat} /> : null}
      </form>

      <div style="display:flex; gap:10px; align-items:center; justify-content:flex-end; flex-wrap: wrap;">
        <div class="subtle">Showing <b>{filtered.length}</b> / {skills.length}</div>
        {categories.length ? (
          <select
            class="select"
            name="cat"
            onchange="const u=new URL(location.href); if(this.value) u.searchParams.set('cat', this.value); else u.searchParams.delete('cat'); location.href=u.toString();"
          >
            <option value="" selected={!cat}>All categories</option>
            {categories.map((c) => (
              <option value={c} selected={c === cat}>
                {c} ({countsByCat[c]})
              </option>
            ))}
          </select>
        ) : null}
      </div>
    </div>
  </section>

  <div class="card-grid">
    {filtered.map((s) => (
      <div class="card">
        <h3><a href={href(`/skills/${s.slug}/`)}>{s.name}</a></h3>
        {s.category ? (
          <div class="subtle" style="font-size: 12px; margin-bottom: 8px;">
            {s.category}
          </div>
        ) : null}
        <p>{s.description || "-"}</p>
        <div class="pills">
          <span class="pill primary">v{s.version || "-"}</span>
          <span class="pill">{s.compatibility || "-"}</span>
        </div>
      </div>
    ))}
  </div>
</Base>

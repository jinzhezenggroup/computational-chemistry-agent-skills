---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = Astro.base || "";
const href = (p: string) => `${base}${p}`;

const REPO = "https://github.com/jinzhezenggroup/computational-chemistry-agent-skills";

export async function getStaticPaths() {
  const skills = await getCollection("skills");
  return skills.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const skills = await getCollection("skills");

const idx = skills.findIndex((s) => s.slug === slug);
if (idx < 0) throw new Error(`Skill not found: ${slug}`);

const skill = skills[idx];
const prev = idx > 0 ? skills[idx - 1] : null;
const next = idx < skills.length - 1 ? skills[idx + 1] : null;

const { Content } = await skill.render();
const fm = skill.data;

const sourcePath = fm.sourcePath || "";
const skillDir = sourcePath.replace(/\/SKILL\.md$/, ""); // e.g. tools/openbabel
const installFolderName = skillDir.split("/").slice(-1)[0] || fm.slug;

const humanInstall = `git clone ${REPO}.git
cd computational-chemistry-agent-skills

# Choose ONE skills directory:
# 1) Per-workspace (recommended)
mkdir -p <your-openclaw-workspace>/skills
cp -r ${skillDir} <your-openclaw-workspace>/skills/

# 2) Shared on this machine
mkdir -p ~/.openclaw/skills
cp -r ${skillDir} ~/.openclaw/skills/

# Start a NEW OpenClaw session (skills are snapshotted at session start)
openclaw skills list --eligible
openclaw skills info ${fm.name}`;

const agentInstall = `If you can run commands on the OpenClaw host, you can install it directly:

mkdir -p <workspace>/skills
cp -r ${skillDir} <workspace>/skills/

# Then restart / start a new session to refresh the skill snapshot.
openclaw skills list --eligible
openclaw skills info ${fm.name}`;
---

<Base title={`${fm.name} · Skill`}>
  <div class="subtle" style="margin-bottom: 12px; display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
    <a href={href("/")}>← All skills</a>
    <span class="dot">·</span>
    {prev ? <a href={href(`/skills/${prev.slug}/`)}>← {prev.data.name}</a> : <span class="subtle">← (first)</span>}
    <span class="dot">·</span>
    {next ? <a href={href(`/skills/${next.slug}/`)}>{next.data.name} →</a> : <span class="subtle">(last) →</span>}
  </div>

  <div class="card" style="margin-bottom: 14px;">
    <h1 style="margin: 0 0 6px; font-size: 22px;">{fm.name}</h1>
    {fm.category ? <div class="subtle" style="margin-bottom: 8px;">{fm.category}</div> : null}
    <div class="subtle" style="margin-bottom: 10px;">{fm.description}</div>
    <div class="pills">
      <span class="pill primary">v{fm.version}</span>
      <span class="pill">{fm.compatibility}</span>
      {fm.repository ? (
        <a class="pill" href={fm.repository} target="_blank" rel="noreferrer">repository</a>
      ) : null}
      {fm.sourcePath ? (
        <a class="pill" href={`${REPO}/blob/master/${fm.sourcePath}`} target="_blank" rel="noreferrer">source</a>
      ) : null}
    </div>
  </div>

  <div class="card" style="margin-bottom: 14px;">
    <h2 style="margin: 0 0 10px; font-size: 16px;">Installation</h2>

    <div class="tabs" role="tablist" aria-label="installation tabs">
      <button class="tab" id="tab-human" role="tab" aria-selected="true" aria-controls="panel-human" type="button">Human</button>
      <button class="tab" id="tab-agent" role="tab" aria-selected="false" aria-controls="panel-agent" type="button">Agent</button>
    </div>

    <div id="panel-human" class="tab-panel active" role="tabpanel" aria-labelledby="tab-human">
      <div class="subtle" style="margin-bottom: 8px;">Install <code>{installFolderName}</code> as an OpenClaw skill.</div>
      <article class="prose" style="padding: 12px;">
        <pre><code>{humanInstall}</code></pre>
      </article>
      <div class="subtle" style="margin-top: 8px;">Prerequisites: {fm.compatibility || "-"}</div>
    </div>

    <div id="panel-agent" class="tab-panel" role="tabpanel" aria-labelledby="tab-agent">
      <div class="subtle" style="margin-bottom: 8px;">If you can run commands on the OpenClaw host, you can install it yourself.</div>
      <article class="prose" style="padding: 12px;">
        <pre><code>{agentInstall}</code></pre>
      </article>
    </div>

    <script type="module">
      const tabHuman = document.getElementById('tab-human');
      const tabAgent = document.getElementById('tab-agent');
      const panelHuman = document.getElementById('panel-human');
      const panelAgent = document.getElementById('panel-agent');

      function setTab(which) {
        const isHuman = which === 'human';
        tabHuman?.setAttribute('aria-selected', String(isHuman));
        tabAgent?.setAttribute('aria-selected', String(!isHuman));
        panelHuman?.classList.toggle('active', isHuman);
        panelAgent?.classList.toggle('active', !isHuman);
      }

      tabHuman?.addEventListener('click', () => setTab('human'));
      tabAgent?.addEventListener('click', () => setTab('agent'));
    </script>
  </div>

  <article class="prose">
    <Content />
  </article>
</Base>

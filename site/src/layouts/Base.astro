---
import "../styles/global.css";
const { title = "Computational Chemistry Agent Skills" } = Astro.props;
const base = Astro.base || '';
const href = (p) => `${base}${p}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div>
          <div class="brand"><a href={href('/')}>Computational Chemistry Agent Skills</a></div>
        </div>
        <div class="subtle"><a href="https://github.com/jinzhezenggroup/computational-chemistry-agent-skills">GitHub</a></div>
      </div>
      <slot />
      <div class="footer">
        Built from <code>**/SKILL.md</code>
      </div>
    </div>
  </body>
</html>

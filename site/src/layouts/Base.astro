---
import "../styles/global.css";

const { title = "Computational Chemistry Agent Skills" } = Astro.props;

const base = Astro.base ?? "";
const href = (p: string) => `${base}${p}`;

const LICENSE_ID = "LGPL-3.0";
const REPO = "https://github.com/jinzhezenggroup/computational-chemistry-agent-skills";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="container">
      <header class="topbar">
        <div class="brand-block">
          <a class="brand" href={href('/')}>Computational Chemistry Agent Skills</a>
          <div class="meta">
            <a href={`${REPO}/blob/master/LICENSE`} target="_blank" rel="noreferrer">License: <code>{LICENSE_ID}</code></a>
            <span class="dot">·</span>
            <span>Auto-generated from <code>**/SKILL.md</code></span>
          </div>
        </div>
        <nav class="nav">
          <a href={REPO} target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer">
        <span>Built from <code>**/SKILL.md</code></span>
        <span class="dot">·</span>
        <span>License: <code>{LICENSE_ID}</code></span>
      </footer>
    </div>
  </body>
</html>

---
import "../styles/global.css";

const { title = "Computational Chemistry Agent Skills" } = Astro.props;

const base = Astro.base ?? "";
const href = (p: string) => `${base}${p}`;

const LICENSE_ID = "LGPL-3.0-or-later";
const REPO = "https://github.com/jinzhezenggroup/computational-chemistry-agent-skills";
const ZIP_URL = `${REPO}/archive/refs/heads/master.zip`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="container">
      <header class="topbar">
        <a class="brand" href={href("/")}>Computational Chemistry Agent Skills</a>
        <nav class="nav">
          <a href={ZIP_URL} class="nav-primary" target="_blank" rel="noreferrer">Download repo .zip</a>
          <a href={`${REPO}/blob/master/LICENSE`} target="_blank" rel="noreferrer"><code>{LICENSE_ID}</code></a>
          <a href={REPO} target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="footer">
        <span>License: <code>{LICENSE_ID}</code></span>
        <span class="dot">·</span>
        <span><a href={REPO} target="_blank" rel="noreferrer">Repository</a></span>
      </footer>
    </div>
  </body>
</html>
